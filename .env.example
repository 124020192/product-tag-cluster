# 电商产品信息聚合与分析工具 - 环境变量配置
# 复制此文件为 .env 并填入你的 API 凭证

# 平台: taobao (淘宝) 或 jd (京东)
PLATFORM=taobao

# 万邦 API 凭证 (https://onebound.cn)
APPKEY=your_app_key_here
SECRET=your_secret_here

# 搜索关键词
KEYWORD=空调

# 搜索页数 (1-50, 每页消耗1次API调用)
PAGES=2

# 每页商品数 (最大40)
PAGE_SIZE=40

# 输出格式: json, csv, all
OUTPUT_FORMAT=json

# 输出目录
OUTPUT_DIR=./output